pipeline {
    agent any

    environment {
        IMAGE_NAME = "alaadid/hospitalisation"
    }

    stages {

        stage('Pull Image') {
            steps {
                sh 'docker pull $IMAGE_NAME:latest'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh '''
                docker rm -f hospitalisation || true
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker run -d \
                --name hospitalisation \
                --network my-network \
                -p 8089:8089 \
                $IMAGE_NAME:latest
                '''
            }
        }
    }
}