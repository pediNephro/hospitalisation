pipeline {
    agent any

    environment {
        IMAGE_NAME = "alaadid/hospitalisation"
    }

    stages {

        stage('Fix Docker Permission') {
            steps {
                sh 'chmod 666 /var/run/docker.sock || true'
            }
        }

        stage('Create Network') {
            steps {
                sh '''
                docker network inspect my-network || docker network create my-network
                '''
            }
        }

        stage('Run MySQL') {
            steps {
                sh '''
                docker rm -f mysql || true

                docker run -d \
                --name mysql \
                --network my-network \
                -e MYSQL_ROOT_PASSWORD=root \
                -e MYSQL_DATABASE=hospitalisation \
                mysql:8
                '''
            }
        }

        stage('Pull Image') {
            steps {
                sh 'docker pull $IMAGE_NAME:latest'
            }
        }

        stage('Run App') {
            steps {
                sh '''
                docker rm -f hospitalisation || true

                docker run -d \
                --name hospitalisation \
                --network my-network \
                -p 8089:8089 \
                $IMAGE_NAME:latest
                '''
            }
        }
    }
}